import React, { useState } from "react";
import { View, Text, Pressable, ScrollView } from "react-native";
import { createPaymentIntent, BASE } from "../config/api";

export default function PaymentsScreen() {
  const [out, setOut] = useState<string>("");

  async function run() {
    setOut("creando intent...");
    try {
      const r = await createPaymentIntent({
        amount: 1000,
        currency: "usd",
        bookingId: "app_test_booking",
      });
      setOut(JSON.stringify({ base: BASE, ...r }, null, 2));
    } catch (e: any) {
      setOut(String(e?.message || e));
    }
  }

  return (
    <ScrollView contentContainerStyle={{ padding: 16, gap: 12 }}>
      <Text style={{ fontSize: 22, fontWeight: "700" }}>Payments (Día 2)</Text>

      <Pressable
        onPress={run}
        style={{
          backgroundColor: "#111",
          paddingVertical: 14,
          paddingHorizontal: 16,
          borderRadius: 12,
        }}
      >
        <Text style={{ color: "#fff", fontSize: 16, fontWeight: "700" }}>
          Crear PaymentIntent (USD 10)
        </Text>
      </Pressable>

      <View
        style={{
          borderWidth: 1,
          borderColor: "#ddd",
          borderRadius: 12,
          padding: 12,
          minHeight: 120,
        }}
      >
        <Text selectable style={{ fontFamily: "monospace" }}>
          {out}
        </Text>
      </View>
    </ScrollView>
  );
}
